# Copy to .env and adjust.

# URL of the running `playable-scripts dev` server for the playable you're iterating on.
# Start it yourself in a separate terminal:
#   cd /Users/meitalavitan/sett/src/playables/<playable-name> && npm run dev
# Webpack dev server usually binds to 8080 by default; adjust if you override it.
PLAYABLE_URL=http://localhost:8080

# Aspect ratio of the preview iframe, e.g. "9:16" (portrait phone) or "16:9".
PLAYABLE_ASPECT=9:16
